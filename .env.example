# Database
DB_PASSWORD=changeme
DATABASE_URL=postgresql://transit:changeme@localhost:5432/transit

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated allowed origins (only enforced when NODE_ENV=production)
CORS_ORIGINS=https://transit.megaluke.de

# Firmware build worker
OTA_DIR=./firmware
BUILD_WORKER_URL=http://build-worker:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Security — use a long random string (e.g. openssl rand -hex 32)
ADMIN_SECRET=changeme_long_random_string
SITE_PASSWORD=changeme_site_password
